# ── LLM Provider ─────────────────────────────────────────────────────────────
# Set to "anthropic" to use Claude API, or "ollama" to use a local Ollama model.
LLM_PROVIDER=anthropic

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_api_key_here
ANTHROPIC_MODEL=claude-opus-4-6

# ── Ollama (local LLM) ────────────────────────────────────────────────────────
# Requires Ollama running locally: https://ollama.com
# Start with: ollama serve
# Pull a model first: ollama pull llama3   (or mistral, gemma2, phi3, etc.)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
